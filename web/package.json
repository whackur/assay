{
  "name": "assay-web",
  "version": "0.1.0",
  "private": true,
  "description": "Assay project-intelligence web dashboard. Consumes the versioned Rust API contract and renders reports.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "generate:hosted-contract": "node ../scripts/generate-hosted-contract.mjs",
    "check:hosted-contract": "node ../scripts/generate-hosted-contract.mjs --check",
    "dev": "node ../scripts/run-web-tool.mjs next dev",
    "build": "node ../scripts/run-web-tool.mjs next build",
    "start": "node ../scripts/run-web-tool.mjs next start",
    "lint": "node ../scripts/run-web-tool.mjs eslint .",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "jose": "^6.2.3",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.19"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}