{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.assay.dev/project-comparison/v1.json",
  "title": "Assay Project Comparison v1",
  "description": "A one-depth functional-cohort comparison. Discovery stops at one search depth and a discovered candidate never seeds another pass. Similarity is never a quality signal and never implies misconduct; popularity is context only. Unavailable and insufficient states are explicit, never a zero similarity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "comparison_version",
    "mode",
    "status",
    "search_depth",
    "seed",
    "facet_weights",
    "detailed_candidates",
    "additional_candidates",
    "evidence_ids",
    "warnings",
    "limitations"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/schemaVersion" },
    "comparison_version": { "$ref": "#/$defs/versionIdentifier" },
    "mode": {
      "type": "string",
      "enum": ["functional_cohort", "curated_list"]
    },
    "status": { "$ref": "#/$defs/status" },
    "search_depth": {
      "type": "string",
      "const": "one_depth",
      "description": "A discovered candidate never seeds another discovery pass."
    },
    "seed": { "$ref": "#/$defs/repositoryRef" },
    "facet_weights": {
      "type": "array",
      "items": { "$ref": "#/$defs/facetWeight" }
    },
    "detailed_candidates": {
      "type": "array",
      "maxItems": 5,
      "items": { "$ref": "#/$defs/detailedCandidate" }
    },
    "additional_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/compactCandidate" }
    },
    "evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidenceId" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    },
    "limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "functional_cohort" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "detailed_candidates": {
            "items": {
              "properties": {
                "facets": {
                  "minItems": 4,
                  "maxItems": 4,
                  "allOf": [
                    { "contains": { "properties": { "facet": { "const": "problem_overlap" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "feature_overlap" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "technical_similarity" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "structural_similarity" } }, "required": ["facet"] } }
                  ]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "curated_list" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "detailed_candidates": {
            "items": {
              "properties": {
                "facets": {
                  "minItems": 5,
                  "maxItems": 5,
                  "allOf": [
                    { "contains": { "properties": { "facet": { "const": "entry_overlap" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "list_structure" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "unique_coverage" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "editorial_quality" } }, "required": ["facet"] } },
                    { "contains": { "properties": { "facet": { "const": "maintenance_evidence" } }, "required": ["facet"] } }
                  ]
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "versionIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z0-9](?:[a-z0-9._-]*[a-z0-9])?$"
    },
    "machineCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "canonicalFacet": {
      "type": "string",
      "description": "The closed similarity-facet vocabulary. Each mode enumerates its full canonical facet set on every detailed candidate: four facets for functional_cohort and the five curated criteria of specification 7.3 for curated_list.",
      "enum": [
        "problem_overlap",
        "feature_overlap",
        "technical_similarity",
        "structural_similarity",
        "entry_overlap",
        "list_structure",
        "unique_coverage",
        "editorial_quality",
        "maintenance_evidence"
      ]
    },
    "revision": {
      "type": "string",
      "pattern": "^(?!(?:0{40}|0{64})$)(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "evidenceId": {
      "type": "string",
      "pattern": "^evidence:[a-z0-9._-]+:[a-z0-9._-]+(?:[:][a-z0-9._-]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "unavailable",
        "unsupported",
        "insufficient",
        "pending"
      ]
    },
    "unitInterval": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "repositorySource": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "repository_id"],
          "properties": {
            "kind": { "const": "local" },
            "repository_id": { "$ref": "#/$defs/sha256" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "provider", "namespace", "repository"],
          "properties": {
            "kind": { "const": "hosted" },
            "provider": { "$ref": "#/$defs/versionIdentifier" },
            "namespace": { "$ref": "#/$defs/versionIdentifier" },
            "repository": { "$ref": "#/$defs/versionIdentifier" }
          }
        }
      ]
    },
    "hostedRepositorySource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "provider", "namespace", "repository"],
      "properties": {
        "kind": { "const": "hosted" },
        "provider": { "$ref": "#/$defs/versionIdentifier" },
        "namespace": { "$ref": "#/$defs/versionIdentifier" },
        "repository": { "$ref": "#/$defs/versionIdentifier" }
      }
    },
    "repositoryRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "revision"],
      "properties": {
        "source": { "$ref": "#/$defs/repositorySource" },
        "revision": { "$ref": "#/$defs/revision" }
      }
    },
    "hostedRepositoryRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "revision"],
      "properties": {
        "source": { "$ref": "#/$defs/hostedRepositorySource" },
        "revision": { "$ref": "#/$defs/revision" }
      }
    },
    "facetWeight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facet", "weight"],
      "properties": {
        "facet": { "$ref": "#/$defs/canonicalFacet" },
        "weight": { "type": "integer", "minimum": 0 }
      }
    },
    "similarity": {
      "type": "object",
      "additionalProperties": false,
      "description": "A comparability facet value. An unavailable facet has a null value; it is never a zero similarity.",
      "required": ["status", "value"],
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "value": {
          "oneOf": [
            { "$ref": "#/$defs/unitInterval" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "complete" } },
            "required": ["status"]
          },
          "then": { "properties": { "value": { "$ref": "#/$defs/unitInterval" } } },
          "else": { "properties": { "value": { "type": "null" } } }
        }
      ]
    },
    "facetSimilarity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facet", "status", "value"],
      "properties": {
        "facet": { "$ref": "#/$defs/canonicalFacet" },
        "status": { "$ref": "#/$defs/status" },
        "value": {
          "oneOf": [
            { "$ref": "#/$defs/unitInterval" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "complete" } },
            "required": ["status"]
          },
          "then": { "properties": { "value": { "$ref": "#/$defs/unitInterval" } } },
          "else": { "properties": { "value": { "type": "null" } } }
        }
      ]
    },
    "differentiator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token", "evidence_ids"],
      "properties": {
        "token": { "$ref": "#/$defs/machineCode" },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    },
    "popularity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Adoption context only. It never raises a similarity or quality value; it may break an ordering tie.",
      "required": ["stars"],
      "properties": {
        "stars": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        }
      }
    },
    "detailedCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate",
        "selection_reasons",
        "confidence",
        "overall_similarity",
        "facets",
        "popularity",
        "differentiators",
        "evidence_ids"
      ],
      "properties": {
        "candidate": { "$ref": "#/$defs/hostedRepositoryRef" },
        "selection_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/canonicalFacet" }
        },
        "confidence": { "$ref": "#/$defs/unitInterval" },
        "overall_similarity": { "$ref": "#/$defs/similarity" },
        "facets": {
          "type": "array",
          "minItems": 4,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/facetSimilarity" }
        },
        "popularity": { "$ref": "#/$defs/popularity" },
        "differentiators": {
          "type": "object",
          "additionalProperties": false,
          "required": ["seed_only", "candidate_only"],
          "properties": {
            "seed_only": {
              "type": "array",
              "items": { "$ref": "#/$defs/differentiator" }
            },
            "candidate_only": {
              "type": "array",
              "items": { "$ref": "#/$defs/differentiator" }
            }
          }
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    },
    "compactCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "confidence", "overall_similarity", "evidence_ids"],
      "properties": {
        "candidate": { "$ref": "#/$defs/hostedRepositoryRef" },
        "confidence": { "$ref": "#/$defs/unitInterval" },
        "overall_similarity": { "$ref": "#/$defs/similarity" },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "evidence_ids"],
      "properties": {
        "code": { "$ref": "#/$defs/machineCode" },
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    }
  }
}
