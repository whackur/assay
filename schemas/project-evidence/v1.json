{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.assay.dev/project-evidence/v1.json",
  "title": "Assay Project Evidence v1",
  "description": "A citable, content-bounded project fact or explicit availability envelope. It contains no raw diff, credential, absolute host path, private source text, or person-level score.",
  "$ref": "#/$defs/projectEvidence",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "versionIdentifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z0-9](?:[a-z0-9._-]*[a-z0-9])?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "revision": {
      "type": "string",
      "pattern": "^(?!(?:0{40}|0{64})$)(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "evidenceId": {
      "type": "string",
      "pattern": "^evidence:[a-z0-9._-]+:[a-z0-9._-]+(?:[:][a-z0-9._-]+)*$"
    },
    "machineCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "unavailable",
        "unsupported",
        "insufficient",
        "pending"
      ]
    },
    "repositorySource": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "repository_id"],
          "properties": {
            "kind": { "const": "local" },
            "repository_id": { "$ref": "#/$defs/sha256" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "provider", "namespace", "repository"],
          "properties": {
            "kind": { "const": "hosted" },
            "provider": { "$ref": "#/$defs/versionIdentifier" },
            "namespace": { "$ref": "#/$defs/versionIdentifier" },
            "repository": { "$ref": "#/$defs/versionIdentifier" }
          }
        }
      ]
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility", "source_content", "external_transmission"],
      "properties": {
        "visibility": {
          "type": "string",
          "enum": ["public", "private_local"]
        },
        "source_content": {
          "type": "string",
          "enum": ["not_retained", "content_addressed_cache", "explicit_retention"]
        },
        "external_transmission": {
          "type": "string",
          "enum": ["not_requested", "prohibited", "consent_required", "consented"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "visibility": { "const": "private_local" } },
            "required": ["visibility"]
          },
          "then": {
            "properties": {
              "external_transmission": {
                "enum": ["prohibited", "consent_required", "consented"]
              }
            }
          }
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "collected_at",
        "repository_revision",
        "content_hash",
        "remote_record_id"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "repository",
            "repository_content",
            "repository_history",
            "platform_record",
            "reported_ci",
            "release_artifact",
            "documentation",
            "package_registry",
            "comparison_corpus"
          ]
        },
        "collected_at": { "$ref": "#/$defs/timestamp" },
        "repository_revision": {
          "oneOf": [
            { "$ref": "#/$defs/revision" },
            { "type": "null" }
          ]
        },
        "content_hash": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "remote_record_id": {
          "type": ["string", "null"],
          "maxLength": 200,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))[A-Za-z0-9._:/-]+$"
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_category", "tags", "rule_id", "confidence"],
      "properties": {
        "primary_category": {
          "type": "string",
          "enum": [
            "production_code",
            "test",
            "documentation",
            "ci_cd",
            "infrastructure",
            "schema_migration",
            "dependency",
            "security",
            "configuration",
            "generated",
            "vendored",
            "build_output",
            "coverage",
            "unknown"
          ]
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "production",
              "test",
              "documentation",
              "ci_cd",
              "infrastructure",
              "migration",
              "dependency",
              "lockfile",
              "security",
              "configuration",
              "generated",
              "vendored",
              "build_output",
              "coverage",
              "minified"
            ]
          }
        },
        "rule_id": { "$ref": "#/$defs/machineCode" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "rule_id", "attribute_name", "attribute_value"],
                "properties": {
                  "kind": { "const": "policy_rule" },
                  "rule_id": { "$ref": "#/$defs/machineCode" },
                  "attribute_name": { "type": "null" },
                  "attribute_value": { "type": "null" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "rule_id", "attribute_name", "attribute_value"],
                "properties": {
                  "kind": { "const": "linguist_attribute" },
                  "rule_id": { "$ref": "#/$defs/machineCode" },
                  "attribute_name": { "enum": ["linguist-generated", "linguist-vendored"] },
                  "attribute_value": { "type": "boolean" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "rule_id", "attribute_name", "attribute_value"],
                "properties": {
                  "kind": { "const": "attribute_facts_unavailable" },
                  "rule_id": { "$ref": "#/$defs/machineCode" },
                  "attribute_name": { "type": "null" },
                  "attribute_value": { "type": "null" }
                }
              }
            ]
          }
        }
      }
    },
    "trackedFilePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "mode",
        "object_kind",
        "object_id",
        "content_status",
        "language",
        "language_status",
        "size_bytes",
        "content_hash",
        "issue"
      ],
      "properties": {
        "kind": { "const": "tracked_file" },
        "path": {
          "type": "object",
          "additionalProperties": false,
          "required": ["encoding", "value"],
          "properties": {
            "encoding": { "type": "string", "enum": ["utf8", "git_path_hex"] },
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 8192,
              "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000\\\\]+$"
            }
          },
          "allOf": [{
            "if": { "properties": { "encoding": { "const": "git_path_hex" } }, "required": ["encoding"] },
            "then": { "properties": { "value": { "pattern": "^(?:[0-9a-f]{2})+$" } } }
          }]
        },
        "mode": {
          "type": "string",
          "enum": ["regular", "executable", "symbolic_link", "gitlink"]
        },
        "object_kind": { "type": "string", "enum": ["blob", "commit"] },
        "object_id": { "$ref": "#/$defs/revision" },
        "content_status": { "type": "string", "enum": ["complete", "partial", "unavailable", "unsupported"] },
        "language": { "type": ["string", "null"], "enum": ["JavaScript", "Python", "TSX", "TypeScript", null] },
        "language_status": { "type": "string", "enum": ["complete", "unsupported"] },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "content_hash": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "issue": {
          "type": ["string", "null"],
          "enum": ["gitlink_content", "size_limit", "missing_or_unreadable", "timeout", "output_limit", "malformed_metadata", null]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "language_status": { "const": "complete" } }, "required": ["language_status"] },
          "then": { "properties": { "language": { "type": "string" } } },
          "else": { "properties": { "language": { "type": "null" } } }
        },
        {
          "if": { "properties": { "mode": { "const": "gitlink" } }, "required": ["mode"] },
          "then": {
            "properties": {
              "object_kind": { "const": "commit" },
              "content_status": { "const": "unsupported" },
              "size_bytes": { "type": "null" },
              "content_hash": { "type": "null" },
              "issue": { "const": "gitlink_content" }
            }
          },
          "else": { "properties": { "object_kind": { "const": "blob" } } }
        },
        {
          "if": { "properties": { "content_status": { "const": "complete" } }, "required": ["content_status"] },
          "then": {
            "properties": {
              "size_bytes": { "type": "integer" },
              "content_hash": { "$ref": "#/$defs/sha256" },
              "issue": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "issue": { "const": "size_limit" } }, "required": ["issue"] },
          "then": {
            "properties": {
              "content_status": { "const": "partial" },
              "size_bytes": { "type": "integer" },
              "content_hash": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "content_status": { "const": "partial" } }, "required": ["content_status"] },
          "then": {
            "properties": {
              "size_bytes": { "type": "integer" },
              "content_hash": { "type": "null" },
              "issue": { "const": "size_limit" }
            }
          }
        },
        {
          "if": { "properties": { "content_status": { "const": "unavailable" } }, "required": ["content_status"] },
          "then": {
            "properties": {
              "size_bytes": { "type": "null" },
              "content_hash": { "type": "null" },
              "issue": { "enum": ["missing_or_unreadable", "timeout", "output_limit", "malformed_metadata"] }
            }
          }
        },
        {
          "if": { "properties": { "content_status": { "const": "unsupported" } }, "required": ["content_status"] },
          "then": {
            "properties": {
              "mode": { "const": "gitlink" },
              "object_kind": { "const": "commit" },
              "size_bytes": { "type": "null" },
              "content_hash": { "type": "null" },
              "issue": { "const": "gitlink_content" }
            }
          }
        }
      ]
    },
    "fileClassificationPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source_evidence_id", "policy_version", "reason", "classification"],
      "properties": {
        "kind": { "const": "file_classification" },
        "source_evidence_id": { "$ref": "#/$defs/evidenceId" },
        "policy_version": { "$ref": "#/$defs/versionIdentifier" },
        "reason": {
          "type": ["string", "null"],
          "enum": ["attributes_unavailable", null]
        },
        "classification": {
          "allOf": [
            { "$ref": "#/$defs/classification" },
            { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
          ]
        }
      }
    },
    "parentDeltaPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "changed_entries", "renames", "issue"],
      "properties": {
        "kind": { "const": "parent_delta" },
        "changed_entries": { "type": ["integer", "null"], "minimum": 0 },
        "renames": { "type": ["integer", "null"], "minimum": 0 },
        "issue": {
          "type": ["string", "null"],
          "enum": ["shallow_repository", "rename_candidate_limit", null]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "issue": { "type": "null" } }, "required": ["issue"] },
          "then": {
            "properties": {
              "changed_entries": { "type": "integer" },
              "renames": { "type": "integer" }
            }
          }
        },
        {
          "if": { "properties": { "issue": { "const": "rename_candidate_limit" } }, "required": ["issue"] },
          "then": {
            "properties": {
              "changed_entries": { "type": "integer" },
              "renames": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "issue": { "const": "shallow_repository" }
            },
            "required": ["issue"]
          },
          "then": {
            "properties": {
              "changed_entries": { "type": "null" },
              "renames": { "type": "null" }
            }
          }
        }
      ]
    },
    "repositorySnapshotPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "commit_time", "root_tree"],
      "properties": {
        "kind": { "const": "repository_snapshot" },
        "commit_time": { "$ref": "#/$defs/timestamp" },
        "root_tree": {
          "oneOf": [
            { "$ref": "#/$defs/revision" },
            { "type": "null" }
          ]
        }
      }
    },
    "filePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "relative_path",
        "language",
        "language_status",
        "size_bytes",
        "content_hash",
        "classification"
      ],
      "properties": {
        "kind": { "const": "file" },
        "relative_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000\\\\]+$"
        },
        "language": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 64
        },
        "language_status": { "$ref": "#/$defs/status" },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "content_hash": { "$ref": "#/$defs/sha256" },
        "classification": { "$ref": "#/$defs/classification" }
      }
    },
    "repositoryFeaturePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "feature", "state", "related_evidence_ids"],
      "properties": {
        "kind": { "const": "repository_feature" },
        "feature": {
          "type": "string",
          "enum": [
            "readme",
            "license",
            "package_manifest",
            "ci",
            "test",
            "documentation",
            "migration",
            "dependency",
            "security_policy",
            "generated_content",
            "vendored_content"
          ]
        },
        "state": {
          "type": "string",
          "enum": ["present", "absent", "unavailable"]
        },
        "related_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    },
    "historyScopePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "base_revision", "head_revision", "commit_count"],
      "properties": {
        "kind": { "const": "history_scope" },
        "base_revision": {
          "oneOf": [
            { "$ref": "#/$defs/revision" },
            { "type": "null" }
          ]
        },
        "head_revision": { "$ref": "#/$defs/revision" },
        "commit_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "reportedCiPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "workflow_id", "reported_state", "revision"],
      "properties": {
        "kind": { "const": "reported_ci" },
        "workflow_id": { "$ref": "#/$defs/machineCode" },
        "reported_state": {
          "type": "string",
          "enum": [
            "ci_reported_passing",
            "ci_reported_failing",
            "ci_reported_pending",
            "insufficient_evidence"
          ]
        },
        "revision": { "$ref": "#/$defs/revision" }
      }
    },
    "deterministicFindingPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "finding_id", "outcome", "numeric_value", "unit"],
      "properties": {
        "kind": { "const": "deterministic_finding" },
        "finding_id": { "$ref": "#/$defs/machineCode" },
        "outcome": {
          "type": "string",
          "enum": ["positive", "negative", "neutral", "mixed", "unknown"]
        },
        "numeric_value": { "type": ["number", "null"] },
        "unit": {
          "oneOf": [
            { "$ref": "#/$defs/machineCode" },
            { "type": "null" }
          ]
        }
      }
    },
    "claimCorrespondencePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "claim_id",
        "claim_digest",
        "correspondence",
        "implementation_evidence_ids"
      ],
      "properties": {
        "kind": { "const": "claim_correspondence" },
        "claim_id": { "$ref": "#/$defs/machineCode" },
        "claim_digest": { "$ref": "#/$defs/sha256" },
        "correspondence": {
          "type": "string",
          "enum": ["supported", "partially_supported", "unsupported", "unverifiable"]
        },
        "implementation_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        }
      }
    },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/repositorySnapshotPayload" },
        { "$ref": "#/$defs/filePayload" },
        { "$ref": "#/$defs/trackedFilePayload" },
        { "$ref": "#/$defs/fileClassificationPayload" },
        { "$ref": "#/$defs/parentDeltaPayload" },
        { "$ref": "#/$defs/repositoryFeaturePayload" },
        { "$ref": "#/$defs/historyScopePayload" },
        { "$ref": "#/$defs/reportedCiPayload" },
        { "$ref": "#/$defs/deterministicFindingPayload" },
        { "$ref": "#/$defs/claimCorrespondencePayload" }
      ]
    },
    "requestedKind": {
      "type": "string",
      "enum": [
        "repository_snapshot",
        "file",
        "tracked_file",
        "file_classification",
        "parent_delta",
        "repository_feature",
        "history_scope",
        "reported_ci",
        "deterministic_finding",
        "claim_correspondence"
      ]
    },
    "projectEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "repository",
        "id",
        "status",
        "grade",
        "privacy"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schemaVersion" },
        "repository": { "$ref": "#/$defs/repositorySource" },
        "id": { "$ref": "#/$defs/evidenceId" },
        "status": { "$ref": "#/$defs/status" },
        "grade": {
          "type": ["string", "null"],
          "enum": ["a", "b", "c", "d", null]
        },
        "privacy": { "$ref": "#/$defs/privacy" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "payload": { "$ref": "#/$defs/payload" },
        "requested_kind": { "$ref": "#/$defs/requestedKind" },
        "reason": { "$ref": "#/$defs/machineCode" }
        ,
        "related_evidence_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidenceId" }
        },
        "attempted_policy_version": { "$ref": "#/$defs/versionIdentifier" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": { "enum": ["complete", "partial"] }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["provenance", "payload"],
            "properties": {
              "grade": { "enum": ["a", "b", "c", "d"] },
              "provenance": {
                "anyOf": [
                  {
                    "properties": {
                      "repository_revision": { "$ref": "#/$defs/revision" }
                    },
                    "required": ["repository_revision"]
                  },
                  {
                    "properties": {
                      "content_hash": { "$ref": "#/$defs/sha256" }
                    },
                    "required": ["content_hash"]
                  },
                  {
                    "properties": { "remote_record_id": { "type": "string" } },
                    "required": ["remote_record_id"]
                  }
                ]
              }
            },
            "not": {
              "anyOf": [
                { "required": ["requested_kind"] },
                { "required": ["reason"] }
              ]
            }
          },
          "else": {
            "required": ["requested_kind", "reason"],
            "properties": {
              "grade": { "type": "null" }
            },
            "not": {
              "anyOf": [
                { "required": ["provenance"] },
                { "required": ["payload"] }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload": { "properties": { "kind": { "const": "file_classification" } }, "required": ["kind"] },
              "status": { "const": "complete" }
            },
            "required": ["payload", "status"]
          },
          "then": {
            "properties": {
              "payload": {
                "properties": {
                  "reason": { "type": "null" },
                  "classification": {
                    "properties": {
                      "evidence": {
                        "not": {
                          "contains": {
                            "properties": { "kind": { "const": "attribute_facts_unavailable" } },
                            "required": ["kind"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload": { "properties": { "kind": { "const": "file_classification" } }, "required": ["kind"] },
              "status": { "const": "partial" }
            },
            "required": ["payload", "status"]
          },
          "then": {
            "properties": {
              "payload": {
                "properties": {
                  "reason": { "const": "attributes_unavailable" },
                  "classification": {
                    "properties": {
                      "evidence": {
                        "contains": {
                          "properties": { "kind": { "const": "attribute_facts_unavailable" } },
                          "required": ["kind"]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "requested_kind": { "const": "file_classification" } },
            "required": ["requested_kind"]
          },
          "then": {
            "required": ["related_evidence_ids"],
            "properties": {
              "related_evidence_ids": { "minItems": 1, "maxItems": 1 }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "reason": { "const": "missing_classification" } },
                  "required": ["reason"]
                },
                "then": { "not": { "required": ["attempted_policy_version"] } },
                "else": { "required": ["attempted_policy_version"] }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "payload": { "properties": { "kind": { "const": "file_classification" } }, "required": ["kind"] }
            },
            "required": ["payload"]
          },
          "then": {
            "required": ["related_evidence_ids", "attempted_policy_version"],
            "properties": {
              "related_evidence_ids": { "minItems": 1, "maxItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload": { "properties": { "kind": { "const": "parent_delta" } }, "required": ["kind"] },
              "status": { "const": "complete" }
            },
            "required": ["payload", "status"]
          },
          "then": {
            "properties": {
              "payload": { "properties": { "issue": { "type": "null" } } }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload": { "properties": { "kind": { "const": "parent_delta" } }, "required": ["kind"] },
              "status": { "const": "partial" }
            },
            "required": ["payload", "status"]
          },
          "then": {
            "properties": {
              "payload": { "properties": { "issue": { "type": "string" } } }
            }
          }
        },
        {
          "if": {
            "properties": {
              "payload": {
                "properties": {
                  "kind": { "const": "tracked_file" },
                  "content_status": { "const": "complete" }
                },
                "required": ["kind", "content_status"]
              }
            },
            "required": ["payload"]
          },
          "then": { "properties": { "status": { "const": "complete" } } }
        },
        {
          "if": {
            "properties": {
              "payload": {
                "properties": {
                  "kind": { "const": "tracked_file" },
                  "content_status": { "enum": ["partial", "unavailable", "unsupported"] }
                },
                "required": ["kind", "content_status"]
              }
            },
            "required": ["payload"]
          },
          "then": { "properties": { "status": { "const": "partial" } } }
        },
        {
          "if": {
            "properties": {
              "payload": {
                "properties": {
                  "kind": { "const": "repository_feature" },
                  "state": { "const": "unavailable" }
                },
                "required": ["kind", "state"]
              }
            },
            "required": ["payload"]
          },
          "then": { "properties": { "status": { "const": "partial" } } }
        },
        {
          "if": {
            "properties": {
              "payload": {
                "properties": {
                  "kind": { "const": "repository_feature" },
                  "state": { "enum": ["present", "absent"] }
                },
                "required": ["kind", "state"]
              }
            },
            "required": ["payload"]
          },
          "then": { "properties": { "status": { "const": "complete" } } }
        }
      ]
    }
  }
}
