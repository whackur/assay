# Copy to .env.production on the deployment host, then chmod 600.
# For local development, copy to .env and use compose.hosted.yaml.
# Never commit either file. All secret values intentionally remain empty.

# Production requires immutable registry digest references. The deployment
# workflow supplies these automatically. Manual deployments must set values in
# repository@sha256:<64 lowercase hex characters> form.
ASSAY_WEB_IMAGE=
ASSAY_API_IMAGE=
ASSAY_WORKER_IMAGE=
ASSAY_POSTGRES_IMAGE=postgres:18-alpine

# Stable external production volumes. Only the explicit first-install `init`
# command creates them. Routine deploys fail if either configured volume is
# absent. Compose down -v cannot remove external volumes.
ASSAY_POSTGRES_VOLUME=assay-postgres-data-v1
ASSAY_WEB_VOLUME=assay-web-data-v1
ASSAY_BACKUP_DIR=./backups/postgres
ASSAY_WEB_PORT=1019
ASSAY_API_PORT=8080

# PostgreSQL 18 is authoritative. DATABASE_URL uses the internal service name.
POSTGRES_DB=assay
POSTGRES_USER=assay
POSTGRES_PASSWORD=
# Example shape only: postgres://assay:<password>@db:5432/assay
DATABASE_URL=

# Optional read-only GitHub token and idempotent startup seeds.
ASSAY_GITHUB_TOKEN=
ASSAY_SEED_REPOSITORIES=whackur/assay

# Bounded public admission and retry policy.
ASSAY_MAX_ACTIVE_JOBS=8
ASSAY_PUBLIC_COMPLETED_COOLDOWN_SECONDS=1209600
ASSAY_PUBLIC_FAILURE_BACKOFF_SECONDS=60
ASSAY_PUBLIC_BUCKET_WINDOW_SECONDS=600
ASSAY_PUBLIC_BUCKET_COOLDOWN_SECONDS=900
ASSAY_PUBLIC_ANONYMOUS_BURST=4
ASSAY_PUBLIC_OWNER_BURST=3
ASSAY_PUBLIC_PROVIDER_BURST=20
ASSAY_PUBLIC_FAILURE_CIRCUIT_THRESHOLD=3
ASSAY_PUBLIC_FAILURE_CIRCUIT_COOLDOWN_SECONDS=900
ASSAY_PROVIDER_RETRY_MAX_SECONDS=3600

# Leave the trusted IP header unset unless the reverse proxy strips
# client-supplied copies and injects this exact header. Use a random 32+
# character HMAC key when enabling it.
ASSAY_TRUSTED_CLIENT_IP_HEADER=
ASSAY_ADMISSION_HASH_KEY=

# OpenAI-compatible Ollama endpoint. This MUST be an http(s) /v1 base; the
# worker calls {base}/chat/completions with non-streaming JSON output. Examples:
#   http://host.docker.internal:11434/v1
#   https://operator-managed-ollama.example/v1
# The native https://ollama.com/api shape is not supported. When an API key is
# configured, the base URL MUST use HTTPS. Plain HTTP is accepted only without
# a key for localhost, loopback, or host.docker.internal development endpoints.
ASSAY_OLLAMA_BASE_URL=
ASSAY_OLLAMA_API_KEY=
ASSAY_OLLAMA_MODEL=

# Required by the web review queue for server-to-server administrator calls.
ASSAY_INTERNAL_ADMIN_TOKEN=
